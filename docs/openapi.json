dress"}},"type":"object","title":"ContactInfo","description":"Extracted contact information."},"ExtractResponse":{"properties":{"description":{"type":"string","title":"Description","description":"Cleaned plain-text description/scope of work"},"requirements":{"items":{"type":"string"},"type":"array","minItems":1,"title":"Requirements","description":"List of requirements extracted from the tender"},"tender_number":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Tender Number","description":"Tender/bid reference number"},"title":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Title","description":"Tender title or name"},"closing_date":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Closing Date","description":"Submission deadline date"},"closing_time":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Closing Time","description":"Submission deadline time"},"publication_date":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Publication Date","description":"Date tender was published"},"validity_period":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Validity Period","description":"How long the bid must remain valid"},"contract_period":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Contract Period","description":"Duration of the contract"},"issuing_organization":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Issuing Organization","description":"Organization issuing the tender"},"department":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Department","description":"Department within organization"},"delivery_location":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Delivery Location","description":"Where goods/services must be delivered"},"submission_address":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Submission Address","description":"Physical address for bid submission"},"estimated_value":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Estimated Value","description":"Estimated contract value if disclosed"},"bid_bond_required":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Bid Bond Required","description":"Bid guarantee/bond requirements"},"payment_terms":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Payment Terms","description":"Payment terms or conditions"},"bbbee":{"anyOf":[{"$ref":"#/components/schemas/BBBEEInfo"},{"type":"null"}],"description":"B-BBEE requirements and scoring"},"contact":{"anyOf":[{"$ref":"#/components/schemas/ContactInfo"},{"type":"null"}],"description":"Contact person details"},"briefing_session":{"anyOf":[{"$ref":"#/components/schemas/BriefingSession"},{"type":"null"}],"description":"Briefing session or site visit details"},"evaluation_criteria":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Evaluation Criteria","description":"How bids will be evaluated/scored"},"special_conditions":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Special Conditions","description":"Special conditions of contract"},"returnable_documents":{"items":{"type":"string"},"type":"array","title":"Returnable Documents","description":"List of documents to be submitted with bid"},"confidence":{"type":"number","maximum":1.0,"minimum":0.0,"title":"Confidence","description":"Extraction confidence score (0.0-1.0)"},"pages_used":{"items":{"type":"integer"},"type":"array","title":"Pages Used","description":"0-indexed page numbers that were analyzed"},"raw_text_preview":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Raw Text Preview","description":"First 500 chars of extracted text for debugging"}},"type":"object","required":["description","requirements","confidence","pages_used"],"title":"ExtractResponse","description":"Response model for tender extraction results with comprehensive fields."},"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"HealthResponse":{"properties":{"status":{"type":"string","title"